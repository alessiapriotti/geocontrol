# Copia questo file in docker/.env per usare Docker Compose.
# Il file docker/.env è git-ignorato e non deve mai essere committato.

# Application
PORT=5000

# JWT secret — stringa lunga e random (min 40 caratteri)
# ATTENZIONE: non usare $ nel valore, viene interpretato da Docker Compose
SECRET_KEY=change_me_to_a_long_random_secret_string

# Database (MySQL — Docker)
DB_TYPE=mysql
DB_HOST=database
DB_PORT=3306
DB_NAME=geocontrol_db
DB_USERNAME=geocontrol_user
DB_PASSWORD=change_me

# MySQL image variables (devono corrispondere ai DB_* sopra)
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=geocontrol_db
MYSQL_USER=geocontrol_user
MYSQL_PASSWORD=change_me

# Password dell'utente root dell'applicazione
ROOT_USER_PASSWORD=change_me
