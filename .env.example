# Copia questo file in .env per lo sviluppo locale (SQLite, no Docker).
# Il file .env è git-ignorato e non deve mai essere committato.

# Application
PORT=5000

# JWT secret — stringa lunga e random (min 40 caratteri)
# ATTENZIONE: non usare $ nel valore, viene interpretato da Docker Compose e dalle shell
SECRET_KEY=change_me_to_a_long_random_secret_string

# Database (SQLite — sviluppo locale, nessuna configurazione necessaria)
DB_TYPE=sqlite

# Password dell'utente root dell'applicazione (script create-root-user)
ROOT_USER_PASSWORD=change_me
